# WhatsApp Cloud API (Meta)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
GRAPH_API_VERSION=v21.0

# Qwen AI (Dashscope)
DASHSCOPE_API_KEY=
AI_MODEL=qwen3.6-35b-a3b

# Database
# Local development uses data/autopilot.json automatically.
# Set DATABASE_URL when you wire a production PostgreSQL database.
DATABASE_URL=

# Paystack (test mode)
PAYSTACK_SECRET_KEY=
PAYSTACK_CALLBACK_URL=

# Application
OWNER_WHATSAPP_NUMBER=
PORT=3000
NODE_ENV=development
WHATSAPP_DRY_RUN=true
ENABLE_DEV_SIMULATOR=true

# Ngrok (for local webhook)
NGROK_URL=

# Dashboard
DASHBOARD_URL=
